@baseURL = http://localhost:3000
@user_id = 5

### Listar todos os usuários
GET {{baseURL}}/users
Accept: application/json

### Criar um novo usuário
POST {{baseURL}}/users
Content-Type: application/json

{
    "name": "Carlos Almeida",
    "email": "carlos@example.com",
    "password_hash": "hashed_password",
    "role_id": 1
}

### Criar usuário com email inválido (erro esperado)
POST {{baseURL}}/users
Content-Type: application/json

{
    "name": "Teste Email Invalido",
    "email": "email_invalido",
    "password_hash": "hashed_password",
    "role_id": 1
}

### Criar usuário com email repetido (erro esperado)
POST {{baseURL}}/users
Content-Type: application/json

{
    "name": "Carlos Almeida",
    "email": "carlos@example.com",
    "password_hash": "hashed_password",
    "role_id": 1
}

### Atualizar um usuário existente (substitua @user_id)
PUT {{baseURL}}/users/{{user_id}}
Content-Type: application/json

{
    "name": "Carlos de Almeida Atualizado",
    "email": "carlosatualizado@example.com",
    "password_hash": "updated_hashed_password",
    "role_id": 1
}

### Atualizar usuário inexistente (erro esperado)
PUT {{baseURL}}/users/9999
Content-Type: application/json

{
    "name": "Usuario Inexistente",
    "email": "inexistente@example.com",
    "password_hash": "hashed_password",
    "role_id": 1
}

### Deletar um usuário existente (substitua @user_id)
DELETE {{baseURL}}/users/{{user_id}}
Accept: application/json

### Deletar um usuário inexistente (erro esperado)
DELETE {{baseURL}}/users/9999
Accept: application/json